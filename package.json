{
  "name": "school-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "prisma db seed",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "db:setup": "npx prisma db push && npx tsx prisma/seed.ts",
    "postbuild": "npx prisma db push && npx tsx prisma/seed.ts || true",
    "prisma": {
      "seed": "npx tsx prisma/seed.ts"
    }
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.22.0",
    "next": "15.3.3",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
